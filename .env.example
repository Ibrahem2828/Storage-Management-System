APP_NAME="Storage Management System"
NODE_ENV="development"
PORT=4000

DATABASE_PATH="./data/storage.sqlite"

JWT_SECRET="local-dev-secret"
JWT_EXPIRES_IN="1d"

UPLOADS_DIR="./uploads"
CORS_ORIGIN="*"

